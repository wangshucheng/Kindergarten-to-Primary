classDiagram
    direction LR
    class GameShell {
        +config: GameConfig
        +render()
    }
    class GameProps {
        +config: GameConfig
        +sound: SoundManager
        +tts: TtsManager
        +onComplete(r: GameResult)
        +onExit()
    }
    class ScoreContext {
        +score: number
        +combo: number
        +mistakes: number
        +rounds: number
        +knowledgePoints: string[]
        +medals: string[]
        +addScore(n)
        +bumpCombo()
        +addMistake()
        +collectKnowledge(id)
        +unlockMedal(id)
    }
    class TtsManager {
        +speak(text, opts)
        +toggle(): boolean
        +isEnabled(): boolean
    }
    class useTTS {
        +speakZh(text)
        +speakEn(text)
        +toggle()
    }
    class DataLoader {
        +loadHanzi(): HanziEntry[]
        +loadEnglish(): EnglishWord[]
        +loadPinyin(): PinyinData
        +loadMathContent(): MathContent
    }
    class Sampler {
        +pickRandom(arr, rng)
        +pickN(arr, n, rng)
        +pickByLevel(arr, level, rng)
        +pickByTag(arr, tag, rng)
    }
    class QuestionGenerator {
        +hanzi(opts): HanziQuestion[]
        +english(opts): EnglishQuestion[]
        +pinyin(opts): PinyinQuestion[]
        +math(opts): MathExpr[]
        +logic(opts): LogicPuzzle[]
    }
    class MatchDetector {
        +detectMatch3(grid): Coord[]
        +isAdjacent(a, b): boolean
        +findRuns(line): number[][]
    }
    class GridBoard {
        +rows: number
        +cols: number
        +renderCell(pos): ReactNode
    }
    class Brick {
        +emoji/label/sub/tone
        +onClick()
    }
    class Slider {
        +content: ReactNode
        +onTap()
        +onDragTo(dir)
    }
    class useDrag {
        +bind: onPointerDown
        +state: DragState
    }

    GameShell --> GameProps : provides
    GameProps --> ScoreContext : uses(useScore)
    GameProps --> TtsManager : uses(tts)
    useTTS ..> TtsManager : wraps
    QuestionGenerator --> DataLoader : reads
    QuestionGenerator --> Sampler : picks
    MatchDetector .. GameProps : used by play logic
    GridBoard ..> Brick : renders
    Slider ..> useDrag : uses
